POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=bomba_db

# Used by BombaDbContext when running inside Docker (bot service)
# For local dev this env var is not needed - it falls back to localhost
CONNECTION_STRING=Host=postgres;Database=bomba_db;Username=postgres;Password=yourpassword

# Discord bot token (needed when bot service is enabled)
DISCORD_TOKEN=

# OpenRouter API key for generating text embeddings
OPENROUTER_API_KEY=your_openrouter_api_key_here